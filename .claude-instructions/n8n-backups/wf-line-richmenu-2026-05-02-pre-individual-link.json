        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $('トークン確認').first().json.token }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($('トークン確認').first().json.menuData) }}",
        "options": { "response": { "response": { "fullResponse": true } } }
      },
      "id": "rm-create",
      "name": "リッチメニュー作成",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1168, -144]
    },
    {
      "parameters": {
        "jsCode": "const data = $('トークン確認').first().json;\nconst token = data.token;\nconst richMenuId = data.richMenuId;\nconst imageBase64 = data.imageBase64;\nconst contentType = data.imageContentType || 'image/png';\n\nif (!richMenuId || !imageBase64) {\n  throw new Error('richMenuId と imageBase64 は必須です');\n}\n\nconst binaryData = Buffer.from(imageBase64, 'base64');\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: `https://api-data.line.me/v2/bot/richmenu/${richMenuId}/content`,\n  headers: {\n    'Authorization': `Bearer ${token}`,\n    'Content-Type': contentType\n  },\n  body: binaryData,\n  encoding: null,\n  returnFullResponse: true\n});\n\nreturn [{ json: { statusCode: 200, body: {}, action: 'upload_image', richMenuId } }];"
      },
      "id": "rm-upload",
      "name": "リッチメニュー画像アップロード",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1168, 0]
    },
    {
