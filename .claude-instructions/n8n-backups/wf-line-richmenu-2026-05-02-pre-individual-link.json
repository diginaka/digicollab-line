        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $('トークン確認').first().json.token }}" }] },
        "options": { "response": { "response": { "fullResponse": true } } }
      },
      "id": "rm-delete",
      "name": "リッチメニュー削除",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1168, 464]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst action = $('トークン確認').first().json.action;\n\nconst statusCode = input.statusCode || 200;\nconst body = input.body || input;\n\nreturn [{\n  json: {\n    status: 'success',\n    action,\n    data: body,\n    statusCode\n  }\n}];"
      },
      "id": "rm-success",
      "name": "成功レスポンス",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
