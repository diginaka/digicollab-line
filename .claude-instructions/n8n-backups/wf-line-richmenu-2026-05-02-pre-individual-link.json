  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "dc-line-richmenu",
        "responseMode": "responseNode",
        "options": { "allowedOrigins": "*" }
      },
      "id": "rm-trigger",
      "name": "Webhook受信",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, 0],
      "webhookId": "126a466b-efa3-499c-9acd-82439b4291c3",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst action = body.action;\nconst connectionId = body.connection_id;\n\nconst validActions = ['list', 'create', 'upload_image', 'set_default', 'cancel_default', 'delete'];\n\nif (!action || !validActions.includes(action)) {\n  throw new Error(`無効なアクション: ${action}。有効: ${validActions.join(', ')}`);\n}\nif (!connectionId) {\n  throw new Error('connection_id は必須です');\n}\n\nreturn [{\n  json: {\n    action,\n    connection_id: connectionId,\n    richMenuId: body.richMenuId || null,\n    menuData: body.menuData || null,\n    imageBase64: body.imageBase64 || null,\n    imageContentType: body.imageContentType || 'image/png'\n  }\n}];"
      },
      "id": "rm-validate",
      "name": "バリデーション",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [224, 0]
    },
    {
      "parameters": {
        "url": "=https://whpqheywobndaeaikchh.supabase.co/rest/v1/line_connections?id=eq.{{ $json.connection_id }}&select=channel_access_token,is_connected",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "rm-fetch-token",
      "name": "トークン取得",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [448, 0],
      "credentials": {
        "httpHeaderAuth": { "id": "ggbicx9TBJ3h1T5T", "name": "Supabase Header Auth" }
      }
    },
    {
      "parameters": {
        "jsCode": "const prev = $('バリデーション').first().json;\nconst tokenData = $input.first().json;\n\nconst record = Array.isArray(tokenData) ? tokenData[0] : tokenData;\nif (!record || !record.channel_access_token) {\n  throw new Error('LINE接続情報が見つかりません。');\n}\nif (!record.is_connected) {\n  throw new Error('LINE未接続です。');\n}\n\nreturn [{\n  json: {\n    ...prev,\n    token: record.channel_access_token\n  }\n}];"
      },
      "id": "rm-token-check2",
      "name": "トークン確認",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [672, 0]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "list", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "create", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "upload_image", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "set_default", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "cancel_default", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "version": 2 }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.action }}", "rightValue": "delete", "operator": { "type": "string", "operation": "equals" } }] } }
          ]
        },
        "options": {}
      },
      "id": "rm-switch",
      "name": "アクション分岐",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [880, 0]
    },
    {
      "parameters": {
        "url": "https://api.line.me/v2/bot/richmenu/list",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $('トークン確認').first().json.token }}" }] },
        "options": { "response": { "response": { "fullResponse": true } } }
      },
      "id": "rm-list",
      "name": "リッチメニュー一覧取得",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1168, -304]
